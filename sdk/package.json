{
  "name": "offline-layer-sdk",
  "version": "1.0.0",
  "description": "Offline-first SDK for React Native — smart cache, action queue, delta sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["offline", "react-native", "cache", "sync", "sdk"],
  "author": "Offline Layer Team",
  "license": "MIT",
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.18.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react-native": "^0.72.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@react-native-async-storage/async-storage": "<rootDir>/__mocks__/async-storage.ts",
      "@react-native-community/netinfo": "<rootDir>/__mocks__/netinfo.ts"
    }
  }
}
