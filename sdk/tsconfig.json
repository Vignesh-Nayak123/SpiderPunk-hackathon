{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "lib": ["ES2017"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["jest"]
  },
  "include": [
    "index.ts",
    "core/**/*.ts",
    "cache/**/*.ts",
    "queue/**/*.ts",
    "sync/**/*.ts",
    "utils/**/*.ts",
    "__tests__/**/*.ts",
    "__mocks__/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
